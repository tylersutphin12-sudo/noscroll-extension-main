{
  "manifest_version": 3,
  "name": "NoScroll",
  "version": "2.0.0",
  "description": "Reduce distractions from short-form videos and social media feeds.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://www.tiktok.com/*",
    "https://tiktok.com/*",
    "https://www.instagram.com/*",
    "https://instagram.com/*",
    "https://www.facebook.com/*",
    "https://facebook.com/*",
    "https://m.facebook.com/*",
    "https://x.com/*",
    "https://twitter.com/*",
    "https://www.x.com/*",
    "https://www.twitter.com/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon16.png",
      "32": "assets/icon32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["lib/features.js", "content/shared.js", "content/youtube.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.tiktok.com/*", "https://tiktok.com/*"],
      "js": ["lib/features.js", "content/shared.js", "content/tiktok.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.instagram.com/*", "https://instagram.com/*"],
      "js": ["lib/features.js", "content/shared.js", "content/instagram.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://facebook.com/*",
        "https://m.facebook.com/*"
      ],
      "js": ["lib/features.js", "content/shared.js", "content/facebook.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://www.x.com/*",
        "https://www.twitter.com/*"
      ],
      "js": ["lib/features.js", "content/shared.js", "content/twitter.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://reddit.com/*"
      ],
      "js": ["lib/features.js", "content/shared.js", "content/reddit.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "32": "assets/icon32.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
